{
  "name": "autoreview-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=4096 && next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "clean": "rmdir /s /q .next 2>nul || echo Cleaned",
    "docker:build": "docker build -t autoreview-ai .",
    "docker:run": "docker run -p 3000:3000 autoreview-ai",
    "docker:compose": "docker-compose up -d",
    "prod": "NODE_ENV=production npm run build && npm start",
    "analyze": "ANALYZE=true npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.63",
    "@ai-sdk/openai": "^3.0.48",
    "@clerk/nextjs": "^6.36.10",
    "@formspree/react": "^3.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/supabase-js": "^2.91.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.49",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.0",
    "katex": "^0.16.44",
    "langchain": "^1.2.13",
    "lucide-react": "^0.563.0",
    "next": "^16.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "resend": "^6.9.4",
    "svix": "^1.89.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/three": "^0.182.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "latest",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "vitest-tsconfig-paths": "^3.4.1"
  }
