{
  "name": "AutoReview AI Engineering Skills",
  "version": "2.0.0",
  "description": "Project-specific capability map for building AutoReview AI with spec-driven development.",
  "project": {
    "type": "SaaS review management platform",
    "domain": "AI-assisted review import, analytics, reply generation, profile management, platform integrations, Chrome extension workflows",
    "primary_app_url": "https://ai-review-writer.vercel.app",
    "current_stack": {
      "frontend": ["Next.js 16 App Router", "React 19", "TypeScript", "Tailwind CSS", "Framer Motion", "lucide-react"],
      "backend": ["Next.js Route Handlers", "Prisma", "PostgreSQL", "Clerk Auth"],
      "ai": ["LongCat AI", "Google Generative AI where configured", "AI SDK patterns where used"],
      "payments": ["LemonSqueezy checkout and webhooks"],
      "security": ["CSRF protection", "rate limiting", "encrypted credentials", "server-side auth checks"],
      "extension": ["Chrome extension Manifest V3", "content scripts", "background worker", "popup UI"],
      "deployment": ["Vercel", "PWA assets", "Sentry optional"]
    }
  },
  "spec_driven_development": {
    "tooling": {
      "name": "GitHub Spec Kit + SpecKit Plus",
      "cli": "specify and specifyplus",
      "install_command": "uv tool install specify-cli --from git+https://github.com/github/spec-kit.git@v0.8.7 && uv tool install specifyplus",
      "powershell_note": "Use specifyplus instead of sp because sp is a PowerShell alias for Set-ItemProperty.",
      "repo_files": [
        ".specify/memory/constitution.md",
        ".specify/memory/constitutionplus.md",
        ".specify/memory/command-rules.md",
        ".specify/templates/",
        ".specify/scripts/powershell/",
        ".agents/skills/speckit-*",
        ".agents/skills/specplus-*",
        ".agents/skills/context-engineering",
        ".agents/skills/autoreview-real-data",
        "AGENTS.md",
        "specs/"
      ]
    },
    "required_before_code": true,
    "spec_location": "specs/",
    "workflow": [
      "Start by reading AGENTS.md and only the relevant spec.",
      "Define the user problem and success metric.",
      "Write the feature spec before implementation.",
      "List acceptance criteria in Given/When/Then format.",
      "Map data contracts, API routes, environment variables, and permissions.",
      "Identify security, privacy, performance, mobile, and production risks.",
      "Implement only what the spec covers.",
      "Verify against acceptance criteria with typecheck, build, and focused manual checks.",
      "Update the spec when behavior changes."
    ],
    "plus_workflow": [
      "Use specplus-adr for durable architecture decisions.",
      "Use specplus-phr for meaningful work history and handoff.",
      "Use specplus-reverse-engineer before replacing legacy or unclear behavior.",
      "Use specplus-taskstoissues only when issue preparation is requested."
    ],
    "definition_of_ready": [
      "User goal is clear.",
      "Affected pages/components/API routes are named.",
      "Real data source is identified.",
      "Acceptance criteria are testable.",
      "No demo/local-only behavior is accepted unless explicitly marked as development-only."
    ],
    "definition_of_done": [
      "Feature works with real authenticated user data.",
      "No raw secrets, payment details, or OAuth tokens are stored client-side.",
      "Empty states are honest and non-demo.",
      "Mobile and desktop layouts are usable.",
      "TypeScript passes.",
      "Production build passes for release-level changes.",
      "Git diff contains no unrelated rewrites."
    ]
  },
  "context_engineering": {
    "goal": "Use the smallest useful context while preserving correctness.",
    "load_order": [
      "AGENTS.md",
      ".specify/memory/constitution.md",
      "Relevant specs/[feature]/ files",
      "Contracts/data-model only if needed",
      "Target source files by focused line range"
    ],
    "avoid": [
      "node_modules",
      ".next",
      "package-lock.json unless dependency issue",
      "tsconfig.tsbuildinfo",
      "full build logs",
      ".env values"
    ],
    "search_first_commands": [
      "rg --files",
      "rg -n \"keyword\" src chrome-extension prisma",
      "rg -n \"demo|sample|fake|Math.random|localStorage|supabase\" src"
    ],
    "agent_behavior": [
      "Summarize files read and decisions.",
      "Do not reread files without a reason.",
      "Prefer specs and contracts over broad source inspection.",
      "Keep implementation scoped to acceptance criteria."
    ]
  },
  "capabilities": [
    {
      "name": "review_reply_generation",
      "purpose": "Generate high-quality replies to customer reviews with the correct tone, language, and business context.",
      "inputs": ["review text", "rating", "author name", "platform", "tone", "business context"],
      "outputs": ["reply text", "confidence metadata", "human review recommendation"],
      "implementation": ["src/app/api/reviews/generate-reply/route.ts", "src/lib/longcatAI.ts", "src/app/reviews/page.tsx"]
    },
    {
      "name": "real_profile_data",
      "purpose": "Render user profile, stats, platforms, activity, avatar, and achievements from Clerk plus Prisma.",
      "inputs": ["Clerk user", "Prisma User", "Prisma Review", "Prisma ConnectedPlatform"],
      "outputs": ["profile DTO", "real activity timeline", "computed achievements"],
      "implementation": ["src/app/api/user/profile/route.ts", "src/app/api/user/profile/avatar/route.ts", "src/app/profile/page.tsx"]
    },
    {
      "name": "secure_billing_flow",
      "purpose": "Route users to LemonSqueezy checkout without collecting raw card details in the app.",
      "inputs": ["plan id", "billing cycle", "authenticated user"],
      "outputs": ["checkout URL", "webhook subscription update"],
      "implementation": ["src/app/api/checkout/route.ts", "src/components/PaymentMethodManager.tsx", "src/app/subscription/page.tsx", "src/app/api/webhooks/lemonsqueezy/route.ts"]
    },
    {
      "name": "platform_integrations",
      "purpose": "Connect and sync review platforms using OAuth or user-supplied credentials.",
      "inputs": ["platform", "OAuth code or credentials", "authenticated user"],
      "outputs": ["ConnectedPlatform record", "imported Review records", "sync status"],
      "implementation": ["src/app/connect-platforms/page.tsx", "src/app/api/platforms/**", "src/lib/platformIntegrations.ts"]
    },
    {
      "name": "chrome_extension_review_flow",
      "purpose": "Detect reviews in supported web pages and generate replies from the web app backend.",
      "inputs": ["current tab DOM", "review cards", "authenticated/configured app URL"],
      "outputs": ["review list", "generated reply", "copy or insert action"],
      "implementation": ["chrome-extension/manifest.json", "chrome-extension/content/scraper.js", "chrome-extension/popup/popup.html"]
    }
  ],
  "engineering_rules": [
    "Prefer Prisma and server-side API routes for production data.",
    "Use Clerk auth in every user-specific API route.",
    "Use zod or equivalent validation for external input.",
    "Do not introduce new Supabase-backed behavior unless it is part of a migration spec.",
    "Do not store card numbers, CVV, OAuth secrets, access tokens, or platform credentials in localStorage.",
    "Use lucide-react icons instead of emoji/text placeholders in product UI.",
    "Use honest empty states instead of fake demo data.",
    "Keep fallback templates clearly marked as offline/error fallback, never as primary production behavior.",
    "Run npx tsc --noEmit before finishing code changes.",
    "Run npm run build before release, routing, auth, billing, or schema changes."
  ],
  "quality_gates": {
    "security": [
      "Auth check present",
      "User ownership enforced",
      "No secret in client bundle",
      "No raw payment storage",
      "CSRF/rate-limit considered for mutation endpoints"
    ],
    "data": [
      "Source of truth documented",
      "Empty state is real",
      "No Math.random stats",
      "No demo rows unless inside docs/examples only"
    ],
    "ui": [
      "Responsive at mobile and desktop",
      "No text overflow",
      "Icons used for compact controls",
      "Accessible labels for icon-only actions"
    ],
    "verification": [
      "Typecheck passes",
      "Build passes when production surface changes",
      "Relevant API/page manually checked or reason documented"
    ]
  }
}
