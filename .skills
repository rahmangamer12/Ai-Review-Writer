{
  "name": "AutoReview AI Agent",
  "version": "1.0.0",
  "description": "Intelligent SaaS platform for automated customer review management",
  "agent_type": "agentic_ai_system",
  "capabilities": [
    {
      "name": "analyze_sentiment",
      "description": "Analyzes text sentiment and emotion with detailed classification",
      "parameters": {
        "text": "string (required)",
        "language": "string (optional, auto-detected)"
      },
      "returns": {
        "sentiment": "Positive|Negative|Neutral",
        "emotion": "Happy|Angry|Disappointed|Excited|Frustrated|Calm",
        "confidence": "number (0-1)",
        "topics": "array of strings"
      },
      "examples": [
        "This product is amazing! I love it so much!",
        "Terrible service, will never buy again",
        "It's okay, nothing special but works fine"
      ]
    },
    {
      "name": "detect_language",
      "description": "Detects the language and script of the input text",
      "parameters": {
        "text": "string (required)"
      },
      "returns": {
        "language": "English|Urdu|Roman_Urdu",
        "script": "Latin|Arabic|Mixed",
        "confidence": "number (0-1)"
      },
      "examples": [
        "This is great",
        "یہ بہت اچھا ہے",
        "Ye bohat acha hai"
      ]
    },
    {
      "name": "draft_reply",
      "description": "Generates contextually appropriate replies based on review analysis",
      "parameters": {
        "review_context": "object (required)",
        "tone": "string (Professional|Friendly|Desi/Casual)",
        "language": "string (English|Urdu|Roman_Urdu)",
        "sentiment": "string (from analyze_sentiment)",
        "rating": "number (1-5)"
      },
      "returns": {
        "reply": "string",
        "tone_used": "string",
        "language": "string",
        "appropriateness_score": "number (0-1)",
        "needs_human_review": "boolean"
      },
      "examples": [
        {
          "review": "Great product, fast delivery!",
          "tone": "Friendly",
          "expected_reply": "Hey! Thanks for the love! We're thrilled you enjoyed the product and our speedy delivery. 🎉"
        }
      ]
    },
    {
      "name": "auto_approve_check",
      "description": "Determines if a review reply requires human approval",
      "parameters": {
        "rating": "number (1-5)",
        "sentiment": "string (from analyze_sentiment)",
        "emotion": "string (from analyze_sentiment)",
        "has_abusive_language": "boolean",
        "confidence_score": "number (0-1)"
      },
      "returns": {
        "auto_approve": "boolean",
        "reason": "string",
        "risk_level": "Low|Medium|High",
        "recommended_action": "Publish|Draft|Reject"
      },
      "rules": [
        "4-5 stars + Positive sentiment = Auto approve",
        "1-2 stars + Negative sentiment = Needs approval",
        "Any abusive language = Needs approval",
        "Low confidence (< 0.7) = Needs approval"
      ]
    },
    {
      "name": "detect_abusive_language",
      "description": "Identifies potentially inappropriate or abusive content",
      "parameters": {
        "text": "string (required)",
        "language": "string (optional)"
      },
      "returns": {
        "has_abusive_content": "boolean",
        "severity": "None|Mild|Moderate|Severe",
        "flagged_words": "array of strings",
        "confidence": "number (0-1)"
      }
    },
    {
      "name": "extract_topics",
      "description": "Identifies key topics and themes in customer reviews",
      "parameters": {
        "text": "string (required)",
        "context": "string (optional, product/service info)"
      },
      "returns": {
        "topics": "array of objects",
        "main_topic": "string",
        "confidence": "number (0-1)"
      }
    },
    {
      "name": "learn_from_feedback",
      "description": "Improves future responses based on human edits and feedback",
      "parameters": {
        "original_reply": "string",
        "human_edited_reply": "string",
        "review_context": "object",
        "feedback_type": "string (edit|approve|reject)"
      },
      "returns": {
        "learning_applied": "boolean",
        "patterns_identified": "array of strings",
        "improvement_suggestions": "array of strings"
      }
    },
    {
      "name": "generate_dashboard_insights",
      "description": "Creates analytics insights for the 3D dashboard visualization",
      "parameters": {
        "reviews_data": "array of review objects",
        "time_period": "string (day|week|month|quarter)",
        "metrics_requested": "array of strings"
      },
      "returns": {
        "sentiment_distribution": "object",
        "trending_topics": "array of strings",
        "performance_metrics": "object",
        "recommendations": "array of strings"
      }
    }
  ],
  "workflow_rules": [
    {
      "rule": "High Confidence Auto-Reply",
      "condition": "rating >= 4 AND sentiment === 'Positive' AND confidence >= 0.8",
      "action": "auto_reply_and_publish",
      "priority": "High"
    },
    {
      "rule": "Low Confidence Draft",
      "condition": "rating <= 2 OR sentiment === 'Negative' OR confidence < 0.7",
      "action": "create_draft_needs_approval",
      "priority": "Medium"
    },
    {
      "rule": "Abusive Content Flag",
      "condition": "has_abusive_language === true",
      "action": "flag_for_human_review",
      "priority": "Critical"
    },
    {
      "rule": "Multi-language Detection",
      "condition": "language !== 'English'",
      "action": "apply_language_specific_processing",
      "priority": "Medium"
    }
  ],
  "integration_points": [
    "OpenAI GPT-4 for text generation",
    "Supabase for data storage",
    "Vercel AI SDK for streaming responses",
    "React Three Fiber for 3D visualizations"
  ],
  "performance_requirements": {
    "response_time": "< 2 seconds for sentiment analysis",
    "batch_processing": "100 reviews/minute",
    "accuracy_threshold": ">= 85% for sentiment detection",
    "language_support": "English, Urdu, Roman Urdu"
  }
}