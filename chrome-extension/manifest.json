{
  "manifest_version": 3,
  "name": "AutoReview AI - Review Reply Assistant",
  "version": "1.1.1",
  "description": "Generate AI-powered replies to Google, Facebook, Yelp, TripAdvisor, and Trustpilot reviews with one click",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.google.com/*",
    "https://*.facebook.com/*",
    "https://*.yelp.com/*",
    "https://*.tripadvisor.com/*",
    "https://*.trustpilot.com/*",
    "https://ai-review-writer.vercel.app/*",
    "https://autoreview.ai/*",
    "https://autoreview-ai.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AutoReview AI"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://business.google.com/*",
        "https://www.facebook.com/*",
        "https://www.yelp.com/*",
        "https://www.tripadvisor.com/*",
        "https://www.trustpilot.com/*"
      ],
      "js": ["content/scraper.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://ai-review-writer.vercel.app https://autoreview.ai https://autoreview-ai.com"
  }
}
