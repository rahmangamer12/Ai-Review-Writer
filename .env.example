# =============================================
# 🔐 AUTOREVIEW AI - ENVIRONMENT VARIABLES TEMPLATE
# =============================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# 🔑 CLERK AUTHENTICATION
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# 🗄️ SUPABASE DATABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 🔐 ENCRYPTION KEY (Generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# 💳 LEMON SQUEEZY PAYMENT (Optional)
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
LEMONSQUEEZY_VARIANT_STARTER=your_starter_variant_id
LEMONSQUEEZY_VARIANT_PROFESSIONAL=your_professional_variant_id
LEMONSQUEEZY_VARIANT_ENTERPRISE=your_enterprise_variant_id

# 🤖 AI PROVIDERS
LONGCAT_AI_API_KEY=your_longcat_api_key_here
AGENTROUTER_API_KEY=your_agentrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# 🌐 GOOGLE OAUTH (Optional)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# 📘 FACEBOOK OAUTH (Optional)
NEXT_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# 🔍 YELP API (Optional)
YELP_API_KEY=your_yelp_api_key

# 📧 RESEND EMAIL (Optional)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# 🗄️ DATABASE (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/autoreview_ai

# 🔧 APP SETTINGS
NEXT_PUBLIC_APP_URL=https://ai-review-writer.vercel.app

# 🔔 CLERK WEBHOOK (Optional)
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# 🎯 SCHEDULER (Optional)
SCHEDULER_SECRET=your_scheduler_secret_here

# Browser extension and external review webhook security
# CHROME_EXTENSION_ID must match the published extension ID exactly.
CHROME_EXTENSION_ID=your_chrome_extension_id_here
CHROME_EXTENSION_SHARED_SECRET=generate_a_strong_random_secret_here
REVIEWS_WEBHOOK_SECRET=generate_a_strong_random_secret_here

# 🐛 DEBUG MODE (Optional)
NEXT_PUBLIC_DEBUG_MODE=false
LOG_ERRORS=true

# ⚡ UPSTASH REDIS (Optional — for rate limiting + caching)
# Sign up at https://upstash.com (free tier available)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# 🐛 SENTRY ERROR TRACKING (Optional - FREE tier available)
# 1. Sign up at https://sentry.io (FREE)
# 2. Create a new project → Select "Next.js"
# 3. Go to Project Settings → Client Keys (DSN)
# 4. Copy the DSN and paste below
# 5. Set ENABLE_SENTRY=true
SENTRY_DSN=your_sentry_dsn_here
ENABLE_SENTRY=false
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=autoreview-ai

# 🔐 ADMIN KEY (Generate with: node scripts/generate-secrets.js)
ADMIN_KEY=your_admin_key_here
