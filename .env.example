# =============================================
# 🔐 AUTOREVIEW AI - ENVIRONMENT CONFIGURATION
# =============================================

# 🔑 CLERK AUTHENTICATION (Required for production)
# Get from: https://dashboard.clerk.com
# Add your actual keys here for production
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# 🗄️ SUPABASE DATABASE (Required for production)
# Get from: https://supabase.com - Create a free project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# 💳 LEMON SQUEEZY PAYMENT (Required for production subscriptions)
# STEP 1: Go to https://app.lemonsqueezy.com/register
# STEP 2: Create a store
# STEP 3: Go to Settings > API
# STEP 4: Copy API Key and Store ID
# STEP 5: Create products (Starter $19, Professional $49, Enterprise)
# STEP 6: Copy Variant IDs from each product
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Product Variant IDs (Get from Lemon Squeezy Dashboard > Products)
LEMONSQUEEZY_VARIANT_STARTER=your_starter_variant_id
LEMONSQUEEZY_VARIANT_PROFESSIONAL=your_professional_variant_id
LEMONSQUEEZY_VARIANT_ENTERPRISE=your_enterprise_variant_id

# 🤖 AI PROVIDERS
# Get from LongCat AI: https://longcat.ai
LONGCAT_AI_API_KEY=your_longcat_ai_api_key
# Optional - Get from OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 🌐 PLATFORM INTEGRATIONS (Optional for production)
# Google OAuth (Required for Google My Business integration)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth (Required for Facebook integration)
NEXT_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Yelp API (Required for Yelp integration)
YELP_API_KEY=your_yelp_api_key

# TripAdvisor API (Required for TripAdvisor integration)
TRIPADVISOR_API_KEY=your_tripadvisor_api_key

# 🌐 APP SETTINGS
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# 🔐 Security
# Add your allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
