# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files - NEVER track these for production!
.env.local
.env*.local
.env.production
.env.backup

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ===== PERSONAL/PRIVATE FILES (NOT IN GIT!) =====
# Claude context (personal developer info)
.claude/

# Motivation folder (personal career plans)
motivation/

# Any personal notes
**/PERSONAL_*.md
**/MY_*.txt
**/*_PRIVATE.txt
**/*_PERSONAL.*
